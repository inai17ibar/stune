{
  "name": "stune",
  "version": "1.0.0",
  "description": "Music manager for Mac and Sony Walkman",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build && electron-builder"
  },
  "keywords": ["music", "walkman", "sony"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "electron": "^40.6.1",
    "music-metadata": "^11.12.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "electron-builder": "^26.8.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.stune.app",
    "productName": "sTune",
    "mac": {
      "category": "public.app-category.music"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
